<!DOCTYPE html>
<html lang="hr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>AI Chatbot — Tvoj pametni asistent</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet">
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --bg: #F7F7F5;
  --surface: #FFFFFF;
  --surface-hover: #F0EFED;
  --text: #1A1A1A;
  --text-secondary: #6B6B6B;
  --text-tertiary: #9B9B9B;
  --accent: #2563EB;
  --accent-light: #EFF6FF;
  --accent-text: #1E40AF;
  --border: #E5E5E3;
  --border-light: #F0EFED;
  --success: #059669;
  --success-bg: #ECFDF5;
  --warning: #D97706;
  --warning-bg: #FFFBEB;
  --danger: #DC2626;
  --radius: 12px;
  --radius-sm: 8px;
  --shadow-sm: 0 1px 2px rgba(0,0,0,0.04);
  --shadow: 0 1px 3px rgba(0,0,0,0.06), 0 1px 2px rgba(0,0,0,0.04);
}

body {
  font-family: 'DM Sans', -apple-system, BlinkMacSystemFont, sans-serif;
  background: var(--bg);
  color: var(--text);
  height: 100dvh;
  display: flex;
  overflow: hidden;
}

/* SIDEBAR */
.sidebar {
  width: 280px;
  background: var(--surface);
  border-right: 1px solid var(--border);
  display: flex;
  flex-direction: column;
  flex-shrink: 0;
}

.sidebar-header {
  padding: 20px;
  border-bottom: 1px solid var(--border-light);
  display: flex;
  align-items: center;
  gap: 12px;
}

.logo {
  width: 36px;
  height: 36px;
  background: var(--accent);
  border-radius: var(--radius-sm);
  display: flex;
  align-items: center;
  justify-content: center;
}

.logo svg { width: 20px; height: 20px; }

.sidebar-header h1 {
  font-size: 16px;
  font-weight: 600;
  letter-spacing: -0.01em;
}

.new-chat-btn {
  margin: 16px 16px 8px;
  padding: 10px 16px;
  background: var(--accent);
  color: white;
  border: none;
  border-radius: var(--radius-sm);
  font-family: inherit;
  font-size: 13px;
  font-weight: 500;
  cursor: pointer;
  display: flex;
  align-items: center;
  gap: 8px;
  transition: opacity 0.15s;
}

.new-chat-btn:hover { opacity: 0.9; }

.chat-list {
  flex: 1;
  overflow-y: auto;
  padding: 8px;
}

.chat-item {
  padding: 10px 12px;
  border-radius: var(--radius-sm);
  cursor: pointer;
  font-size: 13px;
  color: var(--text-secondary);
  transition: background 0.1s;
  margin-bottom: 2px;
  display: flex;
  align-items: center;
  gap: 8px;
}

.chat-item:hover { background: var(--surface-hover); }
.chat-item.active { background: var(--accent-light); color: var(--accent-text); font-weight: 500; }
.chat-item svg { width: 16px; height: 16px; flex-shrink: 0; opacity: 0.5; }

/* DOCS SECTION */
.sidebar-section {
  border-top: 1px solid var(--border-light);
  padding: 12px 16px;
}

.sidebar-section-title {
  font-size: 11px;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  color: var(--text-tertiary);
  margin-bottom: 8px;
}

.doc-item {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 6px 0;
  font-size: 12px;
  color: var(--text-secondary);
}

.doc-icon {
  width: 28px;
  height: 28px;
  border-radius: 6px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 11px;
  font-weight: 600;
  flex-shrink: 0;
}

.doc-icon.pdf { background: #FEE2E2; color: #DC2626; }
.doc-icon.xlsx { background: #DCFCE7; color: #16A34A; }
.doc-icon.docx { background: #DBEAFE; color: #2563EB; }
.doc-icon.csv { background: #FEF3C7; color: #D97706; }
.doc-icon.txt { background: var(--surface-hover); color: var(--text-secondary); }

.doc-name {
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.doc-status {
  font-size: 10px;
  padding: 2px 6px;
  border-radius: 4px;
}

.doc-status.ready { background: var(--success-bg); color: var(--success); }
.doc-status.processing { background: var(--warning-bg); color: var(--warning); }

/* MAIN AREA */
.main {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.main-header {
  padding: 16px 24px;
  border-bottom: 1px solid var(--border-light);
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: var(--surface);
}

.main-header-title {
  font-size: 14px;
  font-weight: 500;
}

.model-badge {
  font-size: 11px;
  padding: 4px 10px;
  background: var(--surface-hover);
  border-radius: 20px;
  color: var(--text-secondary);
}

/* MESSAGES */
.messages {
  flex: 1;
  overflow-y: auto;
  padding: 24px;
  display: flex;
  flex-direction: column;
  gap: 24px;
}

.message {
  display: flex;
  gap: 12px;
  max-width: 760px;
  width: 100%;
  margin: 0 auto;
  animation: fadeIn 0.3s ease;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(8px); }
  to { opacity: 1; transform: translateY(0); }
}

.message.user { flex-direction: row-reverse; }

.avatar {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar.assistant-avatar {
  background: var(--accent);
}

.avatar.assistant-avatar svg { width: 18px; height: 18px; }

.avatar.user-avatar {
  background: #8B5CF6;
  color: white;
  font-size: 13px;
  font-weight: 600;
}

.bubble {
  padding: 12px 16px;
  border-radius: var(--radius);
  font-size: 14px;
  line-height: 1.65;
  max-width: 85%;
}

.message.user .bubble {
  background: var(--accent);
  color: white;
  border-bottom-right-radius: 4px;
}

.message.assistant .bubble {
  background: var(--surface);
  border: 1px solid var(--border);
  border-bottom-left-radius: 4px;
}

.bubble p { margin-bottom: 8px; }
.bubble p:last-child { margin-bottom: 0; }
.bubble strong { font-weight: 600; }
.bubble code {
  background: var(--surface-hover);
  padding: 2px 6px;
  border-radius: 4px;
  font-size: 13px;
  font-family: 'SF Mono', 'Fira Code', monospace;
}

.bubble ul, .bubble ol {
  margin: 8px 0;
  padding-left: 20px;
}

.bubble li { margin-bottom: 4px; }

.bubble table {
  width: 100%;
  border-collapse: collapse;
  margin: 12px 0;
  font-size: 13px;
}

.bubble th, .bubble td {
  padding: 8px 12px;
  border: 1px solid var(--border);
  text-align: left;
}

.bubble th {
  background: var(--surface-hover);
  font-weight: 600;
}

/* SOURCES */
.sources {
  display: flex;
  gap: 6px;
  flex-wrap: wrap;
  margin-top: 10px;
}

.source-tag {
  font-size: 11px;
  padding: 4px 10px;
  background: var(--accent-light);
  color: var(--accent-text);
  border-radius: 6px;
  display: flex;
  align-items: center;
  gap: 4px;
  cursor: default;
}

.source-tag svg { width: 12px; height: 12px; }

/* THINKING INDICATOR */
.thinking {
  display: flex;
  gap: 4px;
  padding: 8px 0;
}

.thinking span {
  width: 6px;
  height: 6px;
  background: var(--text-tertiary);
  border-radius: 50%;
  animation: pulse 1.4s ease-in-out infinite;
}

.thinking span:nth-child(2) { animation-delay: 0.2s; }
.thinking span:nth-child(3) { animation-delay: 0.4s; }

@keyframes pulse {
  0%, 80%, 100% { transform: scale(0.6); opacity: 0.4; }
  40% { transform: scale(1); opacity: 1; }
}

/* WELCOME */
.welcome {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding: 40px;
  gap: 16px;
}

.welcome-icon {
  width: 64px;
  height: 64px;
  background: var(--accent-light);
  border-radius: 20px;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 8px;
}

.welcome-icon svg { width: 32px; height: 32px; color: var(--accent); }

.welcome h2 {
  font-size: 22px;
  font-weight: 600;
  letter-spacing: -0.02em;
}

.welcome p {
  color: var(--text-secondary);
  font-size: 14px;
  max-width: 400px;
  line-height: 1.6;
}

.suggestions {
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
  justify-content: center;
  margin-top: 8px;
}

.suggestion-btn {
  padding: 10px 16px;
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  font-family: inherit;
  font-size: 13px;
  color: var(--text-secondary);
  cursor: pointer;
  transition: all 0.15s;
}

.suggestion-btn:hover {
  border-color: var(--accent);
  color: var(--accent);
  background: var(--accent-light);
}

/* INPUT AREA */
.input-area {
  padding: 16px 24px 20px;
  background: var(--surface);
  border-top: 1px solid var(--border-light);
}

.input-wrapper {
  max-width: 760px;
  margin: 0 auto;
  display: flex;
  align-items: flex-end;
  gap: 8px;
  background: var(--bg);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 8px 12px;
  transition: border-color 0.15s;
}

.input-wrapper:focus-within {
  border-color: var(--accent);
  box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.1);
}

.upload-btn {
  width: 36px;
  height: 36px;
  border: none;
  background: none;
  cursor: pointer;
  border-radius: var(--radius-sm);
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--text-tertiary);
  transition: all 0.15s;
  flex-shrink: 0;
}

.upload-btn:hover { background: var(--surface-hover); color: var(--text-secondary); }

.upload-btn svg { width: 20px; height: 20px; }

#message-input {
  flex: 1;
  border: none;
  outline: none;
  font-family: inherit;
  font-size: 14px;
  background: transparent;
  resize: none;
  min-height: 36px;
  max-height: 120px;
  line-height: 1.5;
  padding: 6px 0;
  color: var(--text);
}

#message-input::placeholder { color: var(--text-tertiary); }

.send-btn {
  width: 36px;
  height: 36px;
  border: none;
  background: var(--accent);
  color: white;
  border-radius: var(--radius-sm);
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.15s;
  flex-shrink: 0;
}

.send-btn:hover { opacity: 0.9; }
.send-btn:disabled { opacity: 0.4; cursor: default; }
.send-btn svg { width: 18px; height: 18px; }

/* FILE UPLOAD */
.file-upload-area {
  display: none;
  max-width: 760px;
  margin: 0 auto 12px;
  padding: 20px;
  border: 2px dashed var(--border);
  border-radius: var(--radius);
  text-align: center;
  background: var(--surface);
  cursor: pointer;
  transition: all 0.15s;
}

.file-upload-area.visible { display: block; }
.file-upload-area:hover, .file-upload-area.drag-over {
  border-color: var(--accent);
  background: var(--accent-light);
}

.file-upload-area p {
  font-size: 13px;
  color: var(--text-secondary);
  margin-top: 8px;
}

.file-upload-area .formats {
  font-size: 11px;
  color: var(--text-tertiary);
  margin-top: 4px;
}

.upload-progress {
  display: none;
  max-width: 760px;
  margin: 0 auto 12px;
  padding: 12px 16px;
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  font-size: 13px;
}

.progress-bar {
  height: 4px;
  background: var(--border-light);
  border-radius: 2px;
  margin-top: 8px;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: var(--accent);
  border-radius: 2px;
  width: 0%;
  transition: width 0.3s;
}

/* MOBILE */
@media (max-width: 768px) {
  .sidebar { display: none; }
  .messages { padding: 16px; }
  .input-area { padding: 12px 16px 16px; }
}

/* MARKDOWN RENDERING */
.bubble h1, .bubble h2, .bubble h3 {
  margin: 12px 0 6px;
  font-weight: 600;
}
.bubble h1 { font-size: 18px; }
.bubble h2 { font-size: 16px; }
.bubble h3 { font-size: 15px; }
</style>
</head>
<body>

<!-- SIDEBAR -->
<aside class="sidebar">
  <div class="sidebar-header">
    <div class="logo">
      <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
    </div>
    <h1>AI Chatbot</h1>
  </div>

  <button class="new-chat-btn" onclick="newChat()">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
    Novi razgovor
  </button>

  <div class="chat-list" id="chat-list"></div>

  <div class="sidebar-section">
    <div class="sidebar-section-title">Dokumenti</div>
    <div id="doc-list">
      <p style="font-size: 12px; color: var(--text-tertiary);">Još nema dokumenata</p>
    </div>
  </div>
</aside>

<!-- MAIN -->
<main class="main">
  <div class="main-header">
    <span class="main-header-title" id="chat-title">Novi razgovor</span>
    <span class="model-badge">GPT-4o</span>
  </div>

  <div class="messages" id="messages">
    <div class="welcome" id="welcome">
      <div class="welcome-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z"/><path d="M18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.456 2.456L21.75 6l-1.035.259a3.375 3.375 0 00-2.456 2.456z"/></svg>
      </div>
      <h2>Pozdrav! Kako ti mogu pomoći?</h2>
      <p>Postavljaj pitanja o uploadanim dokumentima, analiziraj Excel podatke, ili jednostavno razgovaraj.</p>
      <div class="suggestions">
        <button class="suggestion-btn" onclick="sendMessage('Sažmi sve uploadane dokumente')">📄 Sažmi dokumente</button>
        <button class="suggestion-btn" onclick="sendMessage('Analiziraj prodajne podatke')">📊 Analiziraj podatke</button>
        <button class="suggestion-btn" onclick="sendMessage('Koji su ključni zaključci iz dokumenata?')">💡 Ključni zaključci</button>
      </div>
    </div>
  </div>

  <div class="input-area">
    <div class="file-upload-area" id="file-upload-area">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--text-tertiary)" stroke-width="1.5"><path d="M12 16V4m0 0l-4 4m4-4l4 4M4 14v4a2 2 0 002 2h12a2 2 0 002-2v-4"/></svg>
      <p>Povuci datoteke ovdje ili klikni za upload</p>
      <p class="formats">PDF, DOCX, XLSX, CSV, TXT</p>
      <input type="file" id="file-input" multiple accept=".pdf,.docx,.xlsx,.csv,.txt" style="display:none">
    </div>
    <div class="upload-progress" id="upload-progress">
      <span id="upload-filename">Uploading...</span>
      <div class="progress-bar"><div class="progress-fill" id="progress-fill"></div></div>
    </div>
    <div class="input-wrapper">
      <button class="upload-btn" onclick="toggleUpload()" title="Upload datoteke">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21.44 11.05l-9.19 9.19a6 6 0 01-8.49-8.49l9.19-9.19a4 4 0 015.66 5.66l-9.2 9.19a2 2 0 01-2.83-2.83l8.49-8.48"/></svg>
      </button>
      <textarea id="message-input" placeholder="Postavi pitanje o dokumentima..." rows="1" onkeydown="handleKey(event)"></textarea>
      <button class="send-btn" id="send-btn" onclick="sendMessage()" disabled>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
      </button>
    </div>
  </div>
</main>

<script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
<script>
// STATE
let conversations = {};
let currentChatId = null;
let documents = [];
let isGenerating = false;

// AUTO-RESIZE TEXTAREA
const input = document.getElementById('message-input');
input.addEventListener('input', function() {
  this.style.height = 'auto';
  this.style.height = Math.min(this.scrollHeight, 120) + 'px';
  document.getElementById('send-btn').disabled = !this.value.trim();
});

// KEYBOARD
function handleKey(e) {
  if (e.key === 'Enter' && !e.shiftKey) {
    e.preventDefault();
    sendMessage();
  }
}

// FILE UPLOAD
function toggleUpload() {
  const area = document.getElementById('file-upload-area');
  area.classList.toggle('visible');
}

const fileUploadArea = document.getElementById('file-upload-area');
const fileInput = document.getElementById('file-input');

fileUploadArea.addEventListener('click', () => fileInput.click());
fileUploadArea.addEventListener('dragover', (e) => { e.preventDefault(); fileUploadArea.classList.add('drag-over'); });
fileUploadArea.addEventListener('dragleave', () => fileUploadArea.classList.remove('drag-over'));
fileUploadArea.addEventListener('drop', (e) => {
  e.preventDefault();
  fileUploadArea.classList.remove('drag-over');
  handleFiles(e.dataTransfer.files);
});
fileInput.addEventListener('change', () => handleFiles(fileInput.files));

async function handleFiles(files) {
  for (const file of files) {
    await uploadFile(file);
  }
  fileUploadArea.classList.remove('visible');
}

async function uploadFile(file) {
  const progress = document.getElementById('upload-progress');
  const filename = document.getElementById('upload-filename');
  const fill = document.getElementById('progress-fill');

  progress.style.display = 'block';
  filename.textContent = `Procesiranje: ${file.name}`;
  fill.style.width = '30%';

  const formData = new FormData();
  formData.append('file', file);

  try {
    const response = await fetch('/.netlify/functions/upload', {
      method: 'POST',
      body: formData,
    });

    fill.style.width = '90%';
    const data = await response.json();

    if (data.success) {
      fill.style.width = '100%';
      documents.push({
        name: file.name,
        type: file.name.split('.').pop().toLowerCase(),
        chunks: data.chunks || 0,
        content: data.content || '',
      });
      renderDocList();
      filename.textContent = `✓ ${file.name} — spreman`;
      setTimeout(() => { progress.style.display = 'none'; }, 2000);
    } else {
      filename.textContent = `✗ Greška: ${data.error}`;
      fill.style.width = '0%';
    }
  } catch (err) {
    filename.textContent = `✗ Greška pri uploadu`;
    fill.style.width = '0%';
    console.error(err);
  }
}

function renderDocList() {
  const list = document.getElementById('doc-list');
  if (documents.length === 0) {
    list.innerHTML = '<p style="font-size:12px;color:var(--text-tertiary)">Još nema dokumenata</p>';
    return;
  }
  list.innerHTML = documents.map(d => `
    <div class="doc-item">
      <div class="doc-icon ${d.type}">${(d.type || '?').toUpperCase()}</div>
      <span class="doc-name">${d.name}</span>
      <span class="doc-status ${d.isKB ? 'ready' : 'ready'}">${d.isKB ? 'Baza' : 'Upload'}</span>
    </div>
  `).join('');
}

// CHAT
function newChat() {
  currentChatId = 'chat_' + Date.now();
  conversations[currentChatId] = { title: 'Novi razgovor', messages: [] };
  renderChatList();
  renderMessages();
}

function switchChat(id) {
  currentChatId = id;
  renderChatList();
  renderMessages();
}

function renderChatList() {
  const list = document.getElementById('chat-list');
  const ids = Object.keys(conversations).reverse();
  list.innerHTML = ids.map(id => `
    <div class="chat-item ${id === currentChatId ? 'active' : ''}" onclick="switchChat('${id}')">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
      ${conversations[id].title}
    </div>
  `).join('');
  document.getElementById('chat-title').textContent = conversations[currentChatId]?.title || 'Novi razgovor';
}

function renderMessages() {
  const container = document.getElementById('messages');
  const msgs = conversations[currentChatId]?.messages || [];

  if (msgs.length === 0) {
    document.getElementById('welcome').style.display = 'flex';
    container.innerHTML = '';
    container.appendChild(document.getElementById('welcome') || createWelcome());
    return;
  }

  const welcome = document.getElementById('welcome');
  if (welcome) welcome.style.display = 'none';

  container.innerHTML = msgs.map(m => {
    const parsed = marked.parse(m.content || '');
    const sourcesHtml = (m.sources || []).map(s =>
      `<span class="source-tag"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/></svg>${s}</span>`
    ).join('');

    return `
      <div class="message ${m.role}">
        <div class="avatar ${m.role}-avatar">
          ${m.role === 'assistant'
            ? '<svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5"><path d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z"/></svg>'
            : 'Ti'}
        </div>
        <div class="bubble">
          ${parsed}
          ${sourcesHtml ? '<div class="sources">' + sourcesHtml + '</div>' : ''}
        </div>
      </div>
    `;
  }).join('');

  container.scrollTop = container.scrollHeight;
}

async function sendMessage(text) {
  if (isGenerating) return;

  const content = text || input.value.trim();
  if (!content) return;

  if (!currentChatId) newChat();

  // Hide welcome
  const welcome = document.getElementById('welcome');
  if (welcome) welcome.style.display = 'none';

  // Add user message
  conversations[currentChatId].messages.push({ role: 'user', content });

  // Update title from first message
  if (conversations[currentChatId].messages.length === 1) {
    conversations[currentChatId].title = content.substring(0, 40) + (content.length > 40 ? '...' : '');
    renderChatList();
  }

  input.value = '';
  input.style.height = 'auto';
  document.getElementById('send-btn').disabled = true;

  renderMessages();

  // Show thinking
  const container = document.getElementById('messages');
  const thinkingEl = document.createElement('div');
  thinkingEl.className = 'message assistant';
  thinkingEl.innerHTML = `
    <div class="avatar assistant-avatar">
      <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5"><path d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z"/></svg>
    </div>
    <div class="bubble"><div class="thinking"><span></span><span></span><span></span></div></div>
  `;
  container.appendChild(thinkingEl);
  container.scrollTop = container.scrollHeight;

  isGenerating = true;

  try {
    // Send additional context from user-uploaded docs (knowledge base is loaded server-side)
    const additionalContext = documents
      .filter(d => d.content)
      .map(d => `[Dokument: ${d.name}]\n${d.content}`)
      .join('\n\n---\n\n');

    const response = await fetch('/.netlify/functions/chat', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        messages: conversations[currentChatId].messages,
        additionalContext: additionalContext || undefined,
      }),
    });

    const data = await response.json();

    container.removeChild(thinkingEl);

    const assistantMsg = {
      role: 'assistant',
      content: data.content || 'Žao mi je, došlo je do greške.',
      sources: data.sources || [],
    };

    conversations[currentChatId].messages.push(assistantMsg);
    renderMessages();

  } catch (err) {
    container.removeChild(thinkingEl);
    conversations[currentChatId].messages.push({
      role: 'assistant',
      content: '⚠️ Greška u komunikaciji sa serverom. Provjeri internet konekciju i pokušaj ponovo.',
    });
    renderMessages();
    console.error(err);
  }

  isGenerating = false;
}

// INIT
newChat();

// Load knowledge base documents
async function loadKnowledgeBase() {
  try {
    const response = await fetch('/.netlify/functions/docs');
    const data = await response.json();
    if (data.documents && data.documents.length > 0) {
      // Show KB docs in sidebar (not editable, just info)
      const kbDocs = data.documents.map(d => ({
        name: d.filename,
        type: d.type === 'excel' ? 'xlsx' : d.type,
        content: null, // content is server-side
        isKB: true,
      }));
      documents = [...kbDocs, ...documents];
      renderDocList();
    }
  } catch (err) {
    console.log('Could not load knowledge base:', err);
  }
}
loadKnowledgeBase();
</script>
</body>
</html>
